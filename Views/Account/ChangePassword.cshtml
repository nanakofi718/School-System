@model SchoolFeesSystem.Models.ViewModels.ChangePasswordVM
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor Accessor

@{
    ViewData["Title"] = "Account Settings";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // Smart Redirect for the Cancel Button
    var role = Accessor.HttpContext?.Session.GetString("Role");
    var cancelController = (role == "Guardian") ? "Guardian" : "Dashboard";
    var cancelAction = (role == "Guardian") ? "Dashboard" : "Index";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-primary text-white p-4 border-0">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-shield-lock me-2"></i> Update Password</h4>
                    <p class="small mb-0 opacity-75">Secure your account by choosing a strong password.</p>
                </div>
                <div class="card-body p-4">

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success border-0 small shadow-sm mb-4">
                            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                        </div>
                    }

                    @if (TempData["Info"] != null)
                    {
                        <div class="alert alert-info border-0 small shadow-sm mb-4">
                            <i class="bi bi-info-circle-fill me-2"></i> @TempData["Info"]
                        </div>
                    }

                    <form asp-action="ChangePassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="form-group mb-3">
                            <label asp-for="CurrentPassword" class="form-label fw-bold small text-muted">Current Password</label>
                            <input asp-for="CurrentPassword" type="password" class="form-control" placeholder="Enter current password" />
                            <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="NewPassword" class="form-label fw-bold small text-muted">New Password</label>
                            <div class="input-group">
                                <input asp-for="NewPassword" type="password" class="form-control" id="newPass" placeholder="New password" />
                                <button class="btn btn-outline-secondary" type="button" onclick="togglePass('newPass')">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="ConfirmPassword" class="form-label fw-bold small text-muted">Confirm New Password</label>
                            <div class="input-group">
                                <input asp-for="ConfirmPassword" type="password" class="form-control" id="confirmPass" placeholder="Confirm new password" />
                                <button class="btn btn-outline-secondary" type="button" onclick="togglePass('confirmPass')">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary py-2 fw-bold rounded-pill shadow-sm">
                                Save New Password
                            </button>
                            <a asp-controller="@cancelController" asp-action="@cancelAction" class="btn btn-light py-2 rounded-pill">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @* Loads jQuery validation so errors show WITHOUT refreshing the page *@
    <partial name="_ValidationScriptsPartial" />

    <script>
        function togglePass(id) {
            const input = document.getElementById(id);
            if (input.type === "password") {
                input.type = "text";
            } else {
                input.type = "password";
            }
        }
    </script>
}