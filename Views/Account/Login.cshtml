@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Login";
}

<style>
    /* Custom styles for the login page to override standard layout backgrounds */
    body {
        background: #f1f5f9; /* Soft slate background */
    }

    .login-container {
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .login-card {
        width: 100%;
        max-width: 400px;
        border: none;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        background: white;
        padding: 2.5rem;
    }

    .form-control {
        background-color: #f8fafc;
        border: 1px solid #e2e8f0;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        margin-bottom: 1.25rem;
    }

        .form-control:focus {
            background-color: #fff;
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }

    .btn-login {
        background-color: #3b82f6;
        color: white;
        font-weight: 600;
        padding: 0.75rem;
        border-radius: 8px;
        border: none;
        width: 100%;
        transition: 0.2s;
    }

        .btn-login:hover {
            background-color: #2563eb;
            transform: translateY(-1px);
        }

    .login-header i {
        font-size: 2.5rem;
        color: #3b82f6;
    }
</style>

<div class="login-container">
    <div class="login-card">
        <div class="login-header text-center mb-4">
            <i class="bi bi-mortarboard-fill mb-2"></i>
            <h4 class="fw-bold">Welcome Back</h4>
            <p class="text-muted small">Please enter your credentials to log in </p>
        </div>

        <form method="post" asp-action="Login">
            <div class="mb-1">
                <label class="form-label small fw-bold text-secondary">Username</label>
                <input name="username" placeholder="Enter your username" class="form-control" required />
            </div>

            <div class="mb-1">
                <label class="form-label small fw-bold text-secondary">Password</label>
                <input name="password" type="password" placeholder="••••••••" class="form-control" required />
            </div>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger py-2 small border-0 mb-3" style="background: #fef2f2; color: #dc2626;">
                    <i class="bi bi-exclamation-circle me-1"></i> @ViewBag.Error
                </div>
            }

            <button type="submit" class="btn btn-login mb-3">
                Sign In
            </button>
        </form>

        <div class="text-center mt-3">
            <p class="small text-muted mb-0">
                Don't have an account?
                <a asp-controller="SignUp" asp-action="Index" class="text-primary fw-bold text-decoration-none">Sign Up </a>
            </p>
        </div>
    </div>
</div>