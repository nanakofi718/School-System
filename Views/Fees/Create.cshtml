@model SchoolFeesSystem.Models.Fee
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Fee Configuration";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="mb-3">
            <a asp-action="Index" class="text-decoration-none text-muted small fw-bold">
                <i class="bi bi-arrow-left me-1"></i> Back to Fee Registry 
            </a>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <div class="bg-soft-primary text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px; background: #e0e7ff;">
                        <i class="bi bi-cash-stack fs-3"></i>
                    </div>
                    <h4 class="fw-bold">Set Class Fees</h4>
                    <p class="text-muted small">Define the billing amount for a specific class and term </p>
                </div>

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="row g-4">
                        <div class="col-md-12">
                            <label asp-for="ClassId" class="form-label small fw-bold text-secondary">Target Class</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-mortarboard text-muted"></i></span>
                                <select asp-for="ClassId" class="form-select border-0 bg-light" asp-items="ViewBag.ClassId">
                                    <option value="">-- Choose Class --</option>
                                </select>
                            </div>
                            <span asp-validation-for="ClassId" class="text-danger x-small"></span> 
                        </div>

                        <div class="col-md-6">
                            <label asp-for="AcademicYear" class="form-label small fw-bold text-secondary">Academic Year</label>
                            <input asp-for="AcademicYear" class="form-control border-0 bg-light" placeholder="e.g. 2025/2026" />
                            <span asp-validation-for="AcademicYear" class="text-danger x-small"></span> 
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Term" class="form-label small fw-bold text-secondary">Term</label>
                            <select asp-for="Term" class="form-select border-0 bg-light">
                                <option value="">-- Select Term --</option>
                                <option>Term 1</option>
                                <option>Term 2</option>
                                <option>Term 3</option>
                            </select>
                            <span asp-validation-for="Term" class="text-danger x-small"></span>
                        </div>

                        <div class="col-md-12">
                            <label asp-for="Amount" class="form-label small fw-bold text-secondary">Amount (GHS)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0 fw-bold">₵</span>
                                <input asp-for="Amount" type="number" step="0.01" class="form-control border-0 bg-light fs-5 fw-bold" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="Amount" class="text-danger x-small"></span>
                        </div>
                    </div>

                    <div class="mt-5">
                        <button type="submit" class="btn btn-primary w-100 py-3 fw-bold shadow-sm">
                            <i class="bi bi-cloud-check me-2"></i> Save Fee Configuration
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="text-center mt-4">
            <p class="text-muted x-small">
                <i class="bi bi-info-circle me-1"></i>
                Fees set here will be applied to all students in the selected class for the designated term. 
            </p>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
     
}