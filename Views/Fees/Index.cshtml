@model IEnumerable<SchoolFeesSystem.Models.Fee>

@{
    ViewData["Title"] = "Fee Registry";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0">Fee Structure</h3>
        <p class="text-muted small">Manage billing rates for classes and academic terms </p>
    </div>
    <a asp-action="Create" class="btn btn-primary rounded-pill shadow-sm">
        <i class="bi bi-plus-circle me-1"></i> Configure New Fee
    </a>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4 py-3 text-uppercase small fw-bold text-muted">Class</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">Academic Period</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">Term</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">Amount</th>
                    <th class="pe-4 py-3 text-end text-uppercase small fw-bold text-muted">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var fee in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <div class="bg-soft-primary rounded p-2 me-3" style="background: #eff6ff;">
                                    <i class="bi bi-book text-primary"></i>
                                </div>
                                <span class="fw-bold">@fee.Class.ClassName</span> 
                            </div>
                        </td>
                        <td>
                            <span class="badge rounded-pill bg-light text-dark border">
                                <i class="bi bi-calendar3 me-1"></i> @fee.AcademicYear
                            </span> 
                        </td>
                        <td>
                            <span class="text-secondary fw-medium">@fee.Term</span> 
                        </td>
                        <td>
                            <span class="fw-bold text-dark">GHS @fee.Amount.ToString("N2")</span> 
                        </td>
                        <td class="pe-4 text-end">
                            <div class="d-flex justify-content-end gap-2">
                                <a asp-action="Edit" asp-route-id="@fee.FeeId" class="btn btn-sm btn-outline-warning rounded-pill px-3">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </a>
                                <form asp-action="Delete" asp-route-id="@fee.FeeId" method="post" class="d-inline" onsubmit="return confirm('WARNING: Deleting this fee will affect all associated student balances. Proceed?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-folder-x fs-1 text-muted"></i>
            <p class="mt-2 text-muted">No fees have been configured yet.</p>
        </div>
    }
</div>

<div class="mt-3">
    <small class="text-muted italic">
        <i class="bi bi-info-circle"></i> Fees are grouped by Class and Term to ensure unique billing cycles.
    </small>
</div>