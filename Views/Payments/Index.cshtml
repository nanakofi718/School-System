@model IEnumerable<SchoolFeesSystem.Models.Payment>

@{
    ViewData["Title"] = "Transaction Ledger";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0">Payment History</h3>
        <p class="text-muted small">A chronological record of all student fee transactions </p>
    </div>
    <a asp-action="Create" class="btn btn-primary rounded-pill shadow-sm">
        <i class="bi bi-plus-lg me-1"></i> Record New Payment
    </a>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4 py-3 text-uppercase small fw-bold text-muted">Date</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">Student & Class</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted text-center">Term</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">Amount</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">Balance After</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">Method</th>
                    <th class="pe-4 py-3 text-end text-uppercase small fw-bold text-muted">Documents</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var payment in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="text-dark fw-medium">@payment.PaymentDate.ToString("dd MMM, yyyy")</div>
                            <small class="text-muted">@payment.PaymentDate.ToString("t")</small> 
                        </td>
                        <td>
                            <div class="fw-bold text-dark">@payment.Student.FullName</div>
                            <div class="small text-primary">@payment.Fee.Class.ClassName</div> 
                        </td>
                        <td class="text-center">
                            <span class="badge bg-light text-dark border fw-normal">@payment.Fee.Term</span> 
                        </td>
                        <td>
                            <span class="text-success fw-bold">+GHS @payment.AmountPaid.ToString("N2")</span> 
                        </td>
                        <td>
                            <span class="fw-semibold @(payment.BalanceAfter > 0 ? "text-danger" : "text-muted")">
                                GHS @payment.BalanceAfter.ToString("N2")
                            </span> 
                        </td>
                        <td>
                            <div class="d-flex align-items-center">
                                <i class="bi @(payment.PaymentMethod.ToString() == "Cash" ? "bi-cash" : "bi-phone-vibrate") me-2 text-muted"></i>
                                <span class="small">@payment.PaymentMethod</span> 
                            </div>
                        </td>
                        <td class="pe-4 text-end">
                            <div class="btn-group shadow-sm rounded-pill overflow-hidden">
                                <a asp-action="Statement"
                                   asp-route-studentId="@payment.StudentId"
                                   asp-route-term="@payment.Fee.Term"
                                   asp-route-academicYear="@payment.Fee.AcademicYear"
                                   class="btn btn-white btn-sm border-end" title="View Full Statement">
                                    <i class="bi bi-file-earmark-text text-info"></i>
                                </a> 
                                <a asp-action="Receipt"
                                   asp-route-id="@payment.PaymentId"
                                   class="btn btn-white btn-sm" title="Generate Receipt">
                                    <i class="bi bi-printer text-success"></i>
                                </a> 
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-journal-x fs-1 text-muted"></i>
            <p class="mt-2 text-muted">No transactions recorded in the ledger yet.</p>
        </div>
    }
</div>

<div class="mt-4 p-3 bg-white rounded shadow-sm border-start border-primary border-4">
    <div class="d-flex align-items-center">
        <i class="bi bi-info-circle-fill text-primary fs-4 me-3"></i>
        <div class="small text-muted">
            <strong>System Tip:</strong> You can click the printer icon to generate a digital PDF receipt for the parent or the document icon to view the student's full payment history for that term. 
        </div>
    </div>
</div>