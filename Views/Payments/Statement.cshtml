@model SchoolFeesSystem.Models.ViewModels.StudentStatementVM

@{
    ViewData["Title"] = "Fee Statement";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4 no-print">
    <div>
        <h3 class="fw-bold mb-0">Financial Statement</h3>
        <p class="text-muted small">Comprehensive payment history for @Model.StudentName </p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-light rounded-pill border">
            <i class="bi bi-arrow-left"></i> Back
        </a>
        <button onclick="window.print()" class="btn btn-dark rounded-pill shadow-sm">
            <i class="bi bi-printer me-1"></i> Print Statement
        </button>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="card-header bg-primary text-white p-4">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h5 class="mb-1 fw-bold">@Model.StudentName</h5>
                <p class="mb-0 opacity-75">@Model.ClassName | @Model.Term — @Model.AcademicYear </p>
            </div>
            <div class="col-md-6 text-md-end mt-3 mt-md-0">
                <div class="badge bg-white text-primary px-3 py-2 fs-6 rounded-pill">
                    Final Balance: GHS @Model.Balance.ToString("N2") 
                </div>
            </div>
        </div>
    </div>

    <div class="card-body bg-light border-bottom p-4">
        <div class="row text-center g-3">
            <div class="col-md-4">
                <small class="text-uppercase fw-bold text-muted d-block mb-1">Total Billable</small>
                <h4 class="fw-bold text-dark">GHS @Model.TotalFee.ToString("N2") </h4>
            </div>
            <div class="col-md-4 border-start border-end">
                <small class="text-uppercase fw-bold text-muted d-block mb-1">Total Paid</small>
                <h4 class="fw-bold text-success">GHS @Model.TotalPaid.ToString("N2") </h4>
            </div>
            <div class="col-md-4">
                <small class="text-uppercase fw-bold text-muted d-block mb-1">Outstanding</small>
                <h4 class="fw-bold text-danger">GHS @Model.Balance.ToString("N2") </h4>
            </div>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-white border-bottom">
                <tr class="text-muted small text-uppercase">
                    <th class="ps-4 py-3">Date</th>
                    <th class="py-3">Description</th>
                    <th class="py-3">Method</th>
                    <th class="py-3">Ref / Check No.</th>
                    <th class="py-3 text-end">Amount</th>
                    <th class="pe-4 py-3 text-end">Balance After</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model.Payments)
                {
                    <tr>
                        <td class="ps-4">@p.Date.ToString("dd MMM, yyyy") </td>
                        <td><span class="fw-medium">Fee Payment</span></td>
                        <td><span class="badge bg-soft-secondary text-secondary" style="background: #f1f5f9;">@p.Method</span></td>
                        <td class="text-monospace small">@p.Reference </td>
                        <td class="text-end text-success fw-bold">+@p.AmountPaid.ToString("N2") </td>
                        <td class="pe-4 text-end fw-semibold">GHS @p.BalanceAfter.ToString("N2") </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    @@media print {
        .no-print, .sidebar, .top-navbar, footer {
            display: none !important;
        }

        .content-area {
            margin-left: 0 !important;
            padding: 0 !important;
        }

        .card {
            border: 1px solid #ddd !important;
            box-shadow: none !important;
        }

        .card-header {
            background-color: #007bff !important;
            color: white !important;
            -webkit-print-color-adjust: exact;
        }
    }
</style>