@model List<SchoolFeesSystem.Models.ViewModels.MonthlyReportVM>
@{
    ViewData["Title"] = "Collection Audit Report";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var selectedTerm = ViewData["SelectedTerm"] as string;
    var selectedYear = ViewData["SelectedYear"] as string;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0">Financial Reports</h3>
        <p class="text-muted small">Detailed audit of collections by class and academic period </p>
    </div>
    <form method="get" asp-controller="Dashboard" asp-action="ExportToExcel">
        <input type="hidden" name="term" value="@selectedTerm" />
        <input type="hidden" name="academicYear" value="@selectedYear" />
        <button type="submit" class="btn btn-outline-success rounded-pill shadow-sm">
            <i class="bi bi-file-earmark-excel me-1"></i> Download Excel
        </button>
    </form>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <label class="form-label small fw-bold text-secondary">Term</label>
                <select name="term" class="form-select border-0 bg-light" asp-items="ViewBag.Terms">
                    <option value="">All Terms</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label small fw-bold text-secondary">Academic Year</label>
                <input type="text" name="academicYear" class="form-control border-0 bg-light"
                       value="@(ViewBag.AcademicYear ?? "")" placeholder="e.g. 2025/2026" /> 
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100 py-2 shadow-sm">
                    <i class="bi bi-search me-2"></i> Filter Records
                </button>
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card border-0 shadow-sm text-center py-5">
        <div class="card-body">
            <i class="bi bi-folder-x fs-1 text-muted"></i>
            <h5 class="mt-3 text-muted">No records found for the selected filters.</h5>
        </div>
    </div>
}
else
{
    @foreach (var group in Model)
    {
        <div class="card border-0 shadow-sm mb-4 overflow-hidden">
            <div class="card-header bg-white py-3 border-0 d-flex justify-content-between align-items-center">
                <div>
                    <span class="badge bg-soft-primary text-primary mb-1" style="background: #e0e7ff;">@group.AcademicYear</span>
                    <h5 class="fw-bold mb-0">@group.ClassName — <span class="text-primary">@group.Term</span> </h5>
                </div>
                <div class="text-end">
                    <small class="text-muted d-block text-uppercase fw-bold" style="font-size: 0.7rem;">Class Total</small>
                    <h5 class="fw-bold text-success mb-0">GHS @group.TotalCollected.ToString("N2")</h5>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr class="text-muted small text-uppercase">
                            <th class="ps-4 py-3">Date</th>
                            <th class="py-3">Student Name</th>
                            <th class="py-3 text-center">Payment Method</th>
                            <th class="py-3">Reference</th>
                            <th class="pe-4 py-3 text-end">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var payment in group.Payments)
                        {
                            <tr>
                                <td class="ps-4">@payment.Date.ToString("dd MMM, yyyy")</td> 
                                <td class="fw-semibold text-dark">@payment.StudentName</td>
                                <td class="text-center">
                                    <span class="badge rounded-pill bg-light text-dark border fw-normal">@payment.PaymentMethod</span>
                                </td>
                                <td class="small text-muted text-monospace">@payment.Reference</td>
                                <td class="pe-4 text-end fw-bold text-success">GHS @payment.AmountPaid.ToString("N2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

<style>
    .bg-soft-primary {
        background-color: #e0e7ff;
    }

    .text-monospace {
        font-family: 'Courier New', Courier, monospace;
    }
</style>