@model IEnumerable<SchoolFeesSystem.Models.Notification>

@{
    ViewData["Title"] = "Communication Audit Log";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0">Notification History</h3>
        <p class="text-muted small">Tracking automated SMS and WhatsApp alerts sent to guardians </p>
    </div>

    <form asp-controller="Payments" asp-action="ProcessNotifications" method="post">
        <button type="submit" class="btn btn-outline-primary rounded-pill shadow-sm">
            <i class="bi bi-arrow-repeat me-1"></i> Retry Pending Alerts
        </button>
    </form>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4 py-3 text-uppercase small fw-bold text-muted">Dispatch Date</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">Recipient (Student)</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">Channel & Message</th>
                    <th class="pe-4 py-3 text-end text-uppercase small fw-bold text-muted">Delivery Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4">
                            <div class="text-dark fw-medium">@item.SentDate.ToString("dd MMM, yyyy")</div>
                            <small class="text-muted">@item.SentDate.ToString("t")</small>
                        </td>
                        <td>
                            <div class="fw-bold text-dark">@item.Student.FullName</div>
                            @if (item.Student.Guardians != null && item.Student.Guardians.Any())
                            {
                                <small class="text-muted"><i class="bi bi-telephone me-1"></i> @item.Student.Guardians.First().Phone</small>
                            }
                        </td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="bg-light rounded p-2 me-3">
                                    <i class="bi @(item.MessageType == "Payment" ? "bi-chat-left-text text-primary" : "bi-whatsapp text-success")"></i>
                                </div>
                                <div class="small text-dark text-truncate" style="max-width: 300px;" title="@item.MessageText">
                                    @item.MessageText
                                </div>
                            </div>
                        </td>
                        <td class="pe-4 text-end">
                            @if (item.Status == "Sent")
                            {
                                <span class="badge rounded-pill bg-soft-success text-success px-3 py-2" style="background: #ecfdf5;">
                                    <i class="bi bi-check-all me-1"></i> Delivered
                                </span>
                            }
                            else if (item.Status == "Pending")
                            {
                                <span class="badge rounded-pill bg-soft-warning text-warning px-3 py-2" style="background: #fffbeb;">
                                    <i class="bi bi-clock-history me-1"></i> Queued
                                </span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-soft-danger text-danger px-3 py-2" style="background: #fef2f2;">
                                    <i class="bi bi-exclamation-triangle me-1"></i> Failed
                                </span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-envelope-x fs-1 text-muted"></i>
            <p class="mt-2 text-muted">No notifications have been dispatched yet.</p>
        </div>
    }
</div>

<div class="mt-4 p-3 bg-white rounded shadow-sm border-start border-info border-4">
    <div class="d-flex align-items-center">
        <i class="bi bi-shield-check text-info fs-4 me-3"></i>
        <div class="small text-muted">
            <strong>Audit Note:</strong> This log captures every automated communication attempt. Statuses are updated in real-time as the messaging service interacts with the Twilio API .
        </div>
    </div>
</div>