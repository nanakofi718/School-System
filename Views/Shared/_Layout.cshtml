@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SchoolFeesSystem</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        :root {
            --sidebar-bg: #1e293b;
            --sidebar-hover: #334155;
            --accent-color: #3b82f6;
            --bg-light: #f8fafc;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-light);
            color: #1e293b;
            overflow-x: hidden;
        }

        .sidebar {
            min-width: 260px;
            max-width: 260px;
            background-color: var(--sidebar-bg);
            height: 100vh;
            position: fixed;
            transition: all 0.3s;
            z-index: 1000;
            box-shadow: 4px 0 10px rgba(0,0,0,0.05);
        }

        .sidebar-header {
            padding: 1.5rem;
            color: white;
            font-weight: 700;
            font-size: 1.25rem;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }

        .sidebar-nav {
            padding: 1rem 0;
        }

        .nav-label {
            padding: 0.5rem 1.5rem;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05rem;
            color: #94a3b8;
            font-weight: 600;
        }

        .sidebar a {
            display: flex;
            align-items: center;
            padding: 0.75rem 1.5rem;
            color: #cbd5e1;
            text-decoration: none;
            transition: 0.2s;
            border-left: 4px solid transparent;
            font-weight: 500;
        }

            .sidebar a i {
                margin-right: 12px;
                font-size: 1.1rem;
            }

            .sidebar a:hover {
                background-color: var(--sidebar-hover);
                color: white;
            }

            .sidebar a.active {
                background-color: rgba(59, 130, 246, 0.1);
                color: var(--accent-color);
                border-left: 4px solid var(--accent-color);
            }

        .top-navbar {
            margin-left: 260px;
            background: white;
            padding: 0.75rem 2rem;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 999;
        }

        .content-area {
            margin-left: 260px;
            padding: 2rem;
            min-height: calc(100vh - 120px);
        }

        footer {
            margin-left: 260px;
            padding: 1.5rem;
            background: white;
            border-top: 1px solid #e2e8f0;
            font-size: 0.875rem;
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-header">
            <i class="bi bi-mortarboard-fill me-2 text-primary"></i> SchoolFees
        </div>
        <div class="sidebar-nav">
            @{
                var role = HttpContextAccessor.HttpContext.Session.GetString("Role");
                var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
            }

            <div class="nav-label">Main</div>

            @if (role == "Guardian")
            {
                <a class="@(currentController == "Guardian" ? "active" : "")" asp-controller="Guardian" asp-action="Dashboard">
                    <i class="bi bi-house-door"></i> Parent Portal
                </a>
            }
            else if (role == "Staff")
            {
                <a class="@(currentController == "Staff" ? "active" : "")" asp-controller="Staff" asp-action="MyClass">
                    <i class="bi bi-house-door"></i> Staff Dashboard
                </a>
            }
            else
            {
                <a class="@(currentController == "Dashboard" ? "active" : "")" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-speedometer2"></i> Admin Dashboard
                </a>
            }

            @if (role == "Admin" || role == "Accountant")
            {
                <div class="nav-label">Management</div>

                <a class="@(currentController == "Payments" ? "active" : "")" asp-controller="Payments" asp-action="Index">
                    <i class="bi bi-credit-card-2-front"></i> All Payments
                </a>

                <a class="@(currentController == "Fees" ? "active" : "")" asp-controller="Fees" asp-action="Index">
                    <i class="bi bi-cash-stack"></i> Fees Setup
                </a>

                <a class="@(currentController == "Classes" ? "active" : "")" asp-controller="Classes" asp-action="Index">
                    <i class="bi bi-door-open"></i> Manage Classes
                </a>

                <a class="@(currentController == "Students" && currentAction == "Index" ? "active" : "")" asp-controller="Students" asp-action="Index">
                    <i class="bi bi-people"></i> All Students
                </a>

                <a class="@(currentAction == "ClearanceList" ? "active" : "")" asp-controller="Students" asp-action="ClearanceList">
                    <i class="bi bi-check2-circle"></i> Clearance Center
                </a>

                <div class="nav-label">Analytics</div>

                <a class="@(currentController == "Dashboard" && currentAction == "Index" ? "active" : "")" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-graph-up"></i> Financial Reports
                </a>
            }

            @if (role == "Staff")
            {
                <div class="nav-label">Classroom</div>
                <a class="@(currentAction == "MyClass" ? "active" : "")" asp-controller="Staff" asp-action="MyClass">
                    <i class="bi bi-mortarboard"></i> My Students
                </a>
                <a class="@(currentController == "Payments" && currentAction == "Create" ? "active" : "")" asp-controller="Payments" asp-action="Create">
                    <i class="bi bi-plus-circle"></i> Collect Fees
                </a>
            }

            @if (role == "Guardian")
            {
                <div class="nav-label">Finance</div>
                <a class="@(currentController == "Guardian" ? "active" : "")" asp-controller="Guardian" asp-action="Dashboard">
                    <i class="bi bi-wallet2"></i> Pay Fees
                </a>
                <a href="#">
                    <i class="bi bi-file-earmark-text"></i> Receipts
                </a>
            }

            <div class="nav-label">Account</div>
            <a class="@(currentAction == "ChangePassword" ? "active" : "")" asp-controller="Account" asp-action="ChangePassword">
                <i class="bi bi-gear"></i> Settings
            </a>
        </div>
    </div>

    <div class="top-navbar">
        <h5 class="mb-0 fw-semibold text-secondary">@ViewData["Title"]</h5>
        <div class="d-flex align-items-center">
            <div class="me-4 d-none d-md-block text-end">
                <small class="text-muted d-block">Welcome back,</small>
                <span class="fw-bold">@HttpContextAccessor.HttpContext.Session.GetString("Username")</span>
                <span class="badge rounded-pill ms-1" style="background: #e0e7ff; color: #4338ca;">@role</span>
            </div>
            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">
                    <i class="bi bi-box-arrow-right me-1"></i> Logout
                </button>
            </form>
        </div>
    </div>

    <div class="content-area">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer>
        <div class="container-fluid text-center">
            &copy; 2026 - <span class="fw-bold text-primary">SchoolFeesSystem</span> | v2.0
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>