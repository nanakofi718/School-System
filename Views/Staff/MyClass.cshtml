@model IEnumerable<SchoolFeesSystem.Models.ViewModels.StudentStatusVM>

@{
    ViewData["Title"] = "My Class Roster";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0">Class Management</h3>
        <p class="text-muted small">Managing Students in <strong>@ViewBag.ClassName</strong></p>
    </div>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light text-muted small text-uppercase">
                <tr>
                    <th class="ps-4 py-3">Student Name</th>
                    <th class="py-3">Financial Status</th>
                    <th class="py-3 text-end">Total Paid</th>
                    <th class="pe-4 py-3 text-end">Balance Due</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var s in Model)
                {
                    var balance = s.TotalBilled - s.TotalPaid;
                    <tr>
                        <td class="ps-4 py-3 fw-bold">@s.FullName</td>
                        <td>
                            @if (balance <= 0)
                            {
                                <span class="badge bg-soft-success text-success rounded-pill px-3" style="background:#ecfdf5;">
                                    <i class="bi bi-check-circle-fill me-1"></i> FULLY PAID
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-soft-danger text-danger rounded-pill px-3" style="background:#fef2f2;">
                                    <i class="bi bi-exclamation-triangle-fill me-1"></i> OWING
                                </span>
                            }
                        </td>
                        <td class="text-end text-success fw-medium">GHS @s.TotalPaid.ToString("N2")</td>
                        <td class="pe-4 text-end fw-bold text-danger">GHS @balance.ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>