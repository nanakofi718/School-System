@model SchoolFeesSystem.Models.Student
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Student Enrollment";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-9 col-xl-8">
        <div class="mb-3">
            <a asp-action="Index" class="text-decoration-none text-muted small fw-bold">
                <i class="bi bi-arrow-left me-1"></i> Back to Student List
            </a>
        </div>

        <div class="card border-0 shadow-sm overflow-hidden">
            <div class="card-header bg-primary py-4 text-center">
                <h4 class="text-white fw-bold mb-0">New Student Registration</h4>
                <p class="text-white-50 small mb-0">Fill in the details to create a new student profile</p>
            </div>

            <div class="card-body p-4 p-md-5">
                <form asp-action="Create" method="post" enctype="multipart/form-data">

                    <div class="row g-4 mb-5">
                        <div class="col-12 border-bottom pb-2">
                            <h5 class="fw-bold text-primary mb-0"><i class="bi bi-person-badge me-2"></i>Personal Details</h5>
                        </div>

                        <div class="col-md-4 text-center border-end">
                            <div class="mb-3">
                                <label class="form-label small fw-bold text-secondary d-block">Student Photo</label>
                                <div class="position-relative d-inline-block">
                                    <img id="imagePreview" src="~/images/default-avatar.png"
                                         class="rounded-3 border shadow-sm"
                                         style="width: 150px; height: 150px; object-fit: cover;" />
                                    <label for="photoInput" class="btn btn-sm btn-dark position-absolute bottom-0 end-0 rounded-circle shadow">
                                        <i class="bi bi-camera-fill"></i>
                                    </label>
                                </div>
                                <input asp-for="PhotoFile" type="file" id="photoInput" class="d-none" accept="image/*" onchange="previewImage(event)" />
                                <span asp-validation-for="PhotoFile" class="text-danger x-small d-block mt-2"></span>
                            </div>
                        </div>

                        <div class="col-md-8">
                            <div class="row g-3">
                                <div class="col-12">
                                    <label asp-for="FullName" class="form-label small fw-bold text-secondary">Full Legal Name</label>
                                    <input asp-for="FullName" class="form-control border-0 bg-light" placeholder="e.g. Kwesi Mensah" />
                                    <span asp-validation-for="FullName" class="text-danger x-small"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="DateOfBirth" class="form-label small fw-bold text-secondary">Date of Birth</label>
                                    <input asp-for="DateOfBirth" type="date" class="form-control border-0 bg-light" />
                                    <span asp-validation-for="DateOfBirth" class="text-danger x-small"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="Gender" class="form-label small fw-bold text-secondary">Gender</label>
                                    <select asp-for="Gender" class="form-select border-0 bg-light">
                                        <option value="">-- Select --</option>
                                        <option value="Male">Male</option>
                                        <option value="Female">Female</option>
                                    </select>
                                    <span asp-validation-for="Gender" class="text-danger x-small"></span>
                                </div>

                                <div class="col-12">
                                    <label asp-for="ClassId" class="form-label small fw-bold text-secondary">Assigned Class</label>
                                    <select asp-for="ClassId" class="form-select border-0 bg-light" asp-items="ViewBag.ClassId">
                                        <option value="">-- Assign a Class --</option>
                                    </select>
                                    <span asp-validation-for="ClassId" class="text-danger x-small"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row g-4 mb-4">
                        <div class="col-12 border-bottom pb-2">
                            <h5 class="fw-bold text-primary mb-0"><i class="bi bi-shield-check me-2"></i>Guardian Information</h5>
                        </div>

                        <input type="hidden" name="Guardians.Index" value="0" />

                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-secondary">Guardian Full Name</label>
                            <input name="Guardians[0].FullName" class="form-control border-0 bg-light" placeholder="Primary Contact Person" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-secondary">Phone Number (SMS Alerts)</label>
                            <input name="Guardians[0].Phone" class="form-control border-0 bg-light" placeholder="+233..." />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-secondary">WhatsApp Number</label>
                            <input name="Guardians[0].WhatsApp" class="form-control border-0 bg-light" placeholder="Optional" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label small fw-bold text-secondary">Email Address</label>
                            <input name="Guardians[0].Email" type="email" class="form-control border-0 bg-light" placeholder="e.g. parent@example.com" />
                        </div>
                    </div>

                    <hr class="my-5" />
                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-primary btn-lg px-5 fw-bold shadow-sm rounded-pill">
                            <i class="bi bi-person-plus-fill me-2"></i> Register Student
                        </button>
                        <a asp-action="Index" class="btn btn-light btn-lg px-4 rounded-pill">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        function previewImage(event) {
            var reader = new FileReader();
            reader.onload = function(){
                var output = document.getElementById('imagePreview');
                output.src = reader.result;
            };
            if(event.target.files[0]) {
                reader.readAsDataURL(event.target.files[0]);
            }
        }
    </script>
}