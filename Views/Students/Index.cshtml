@model IEnumerable<SchoolFeesSystem.Models.Student>

@{
    ViewData["Title"] = "Student Registry";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0">Active Registry</h3>
        <p class="text-muted small">Showing all @Model.Count() students currently enrolled</p>
    </div>
    <a asp-action="Create" class="btn btn-primary rounded-pill shadow-sm px-4">
        <i class="bi bi-person-plus-fill me-2"></i> Register New Student
    </a>
</div>

<div class="card border-0 shadow-sm overflow-hidden">
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3">
                <div class="col-md-5">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" name="searchString" class="form-control border-start-0 ps-0"
                               placeholder="Search by name..." value="@ViewData["CurrentFilter"]" />
                    </div>
                </div>
                <div class="col-md-4">
                    <select name="classFilter" class="form-select border-0 bg-light" asp-items="ViewBag.ClassList">
                        <option value="">-- All Classes --</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100 rounded-pill shadow-sm">
                        Apply Filters
                    </button>
                </div>
            </form>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light text-muted small text-uppercase">
                <tr>
                    <th class="ps-4 py-3">Student</th>
                    <th class="py-3">Class</th>
                    <th class="py-3">Gender</th>
                    <th class="py-3 text-center">Contact</th>
                    <th class="pe-4 py-3 text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in Model)
                {
                    <tr>
                        <td class="ps-4 py-3">
                            <div class="d-flex align-items-center">
                                <img src="@student.PhotoPath" class="rounded-circle border me-3"
                                     style="width:45px; height:45px; object-fit:cover;"
                                     onerror="this.src='/images/default-user.png'" />
                                <div>
                                    <div class="fw-bold text-dark">@student.FullName</div>
                                    <small class="text-muted">ID: #STU-@student.StudentId.ToString("D3")</small>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="badge bg-soft-info text-info rounded-pill px-3" style="background:#e0f2fe;">
                                @student.Class?.ClassName
                            </span>
                        </td>
                        <td>@student.Gender</td>
                        <td class="text-center">
                            @if (student.Guardians != null && student.Guardians.Any())
                            {
                                <span class="text-muted small">
                                    <i class="bi bi-telephone me-1"></i> @student.Guardians.First().Phone
                                </span>
                            }
                        </td>
                        <td class="pe-4 text-end">
                            <a asp-action="Details" asp-route-id="@student.StudentId" class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                <i class="bi bi-eye"></i> Details
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>